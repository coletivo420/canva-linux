+      rememberUploadIngress('input-show-picker', {
+        files: 0,
+        types: 'file-input-picker',
+        target: describeDragTarget(this),
+      });
+      debugLog('upload', 'input-show-picker', `args=${args.length}`, describeDragTarget(this));
     }
