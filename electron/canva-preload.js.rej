+        return handles;
+      } catch (error) {
+        debugLog('upload', 'show-open-file-picker-error', error?.name || 'Error', error?.message || '', `after=${recentUploadIngressSummary()}`);
+        throw error;
+      }
+    };
+
+    try {
+      wrapped.__canvaDebugWrapped = true;
+      scope.showOpenFilePicker = wrapped;
+    } catch {}
+  }
+
+  const inputProto = scope.HTMLInputElement?.prototype;
