{
  "name": "canva-linux",
  "version": "1.4.10-dev.20",
  "description": "A community opensource desktop wrapper for use with Canva",
  "main": "electron/main/index.js",
  "author": "Community",
  "license": "GPL-3.0-or-later",
  "productName": "Canva Linux",
  "homepage": "https://www.canva.com/",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux dir",
    "lint": "eslint .",
    "test": "node --test \"test/**/*.test.js\"",
    "test:unit": "node --test test/window-open-policy.test.js",
    "test:wiring": "node --test test/tab-controller-wiring.test.js",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed",
    "lint:fix": "eslint . --fix",
    "build:preload": "node scripts/build-preload-bundle.js",
    "prestart": "npm run build:preload",
    "predist": "npm run build:preload",
    "docs:check-links": "node scripts/check-doc-links.js",
    "validate:project": "./scripts/validate-project.sh"
  },
  "build": {
    "appId": "io.github.PirateMaryRead.canva-linux",
    "productName": "Canva Linux",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": "dir",
      "category": "Graphics",
      "executableName": "canva-linux",
      "desktop": {
        "entry": {
          "Name": "Canva Linux",
          "StartupWMClass": "io.github.PirateMaryRead.canva-linux",
          "X-GNOME-WMClass": "io.github.PirateMaryRead.canva-linux"
        }
      },
      "icon": "build-resources"
    },
    "extraMetadata": {
      "main": "electron/main/index.js"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "electron": "41.3.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0"
  },
  "desktopName": "io.github.PirateMaryRead.canva-linux.desktop",
  "engines": {
    "node": ">=22.0.0"
  }
}
