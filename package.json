{
  "name": "canva-linux",
  "version": "0.1.4-dev.11.53",
  "description": "A community open-source desktop wrapper for use with Canva",
  "main": ".build/electron/main/index.js",
  "author": "Community",
  "license": "GPL-3.0-or-later",
  "productName": "Canva Linux",
  "homepage": "https://coletivo420.github.io/canva-linux/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coletivo420/canva-linux.git"
  },
  "bugs": {
    "url": "https://github.com/coletivo420/canva-linux/issues"
  },
  "scripts": {
    "start": "electron .",
    "dist": "NODE_OPTIONS=--no-deprecation electron-builder --linux dir",
    "dist:appimage": "npm run build:runtime && NODE_OPTIONS=--no-deprecation electron-builder --linux AppImage --publish=never",
    "lint": "eslint .",
    "test": "node --test \"test/**/*.test.js\"",
    "test:unit": "node --test test/window-open-policy.test.js",
    "test:wiring": "node --test test/tab-controller-wiring.test.js",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed",
    "lint:fix": "eslint . --fix",
    "build:preload": "node scripts/build-preload-bundle.js",
    "clean:runtime": "node scripts/clean-runtime-build.js",
    "build:runtime": "node scripts/build-runtime.js",
    "build:check": "node scripts/check-runtime-build.js",
    "build": "npm run build:runtime",
    "prestart": "npm run build:runtime",
    "predist": "npm run build:runtime",
    "docs:check-links": "node scripts/check-doc-links.js",
    "deps:check-policy": "node scripts/check-dependency-policy.js",
    "typecheck": "tsc --noEmit",
    "validate:project": "./scripts/validate-project.sh",
    "docs:check-ai": "node scripts/check-ai-guardrails.js",
    "typecheck:strict": "tsc -p tsconfig.strict.json --noEmit",
    "build:scripts-core": "esbuild scripts/core/action-registry.ts scripts/core/action-runner.ts scripts/core/validate-actions.ts scripts/core/overview-status.ts scripts/core/check-detection-contract.ts scripts/core/check-version-consistency.ts scripts/core/check-review-checklist.ts scripts/core/check-shell-action-ids.ts --bundle --platform=node --format=cjs --outdir=.build/scripts/core",
    "check:scripts-core": "npm run build:scripts-core && node .build/scripts/core/validate-actions.js && node .build/scripts/core/check-detection-contract.js && node .build/scripts/core/check-version-consistency.js && node .build/scripts/core/check-review-checklist.js && node .build/scripts/core/check-shell-action-ids.js",
    "build:tui": "esbuild scripts/tui/index.ts --bundle --platform=node --format=cjs --external:blessed --outfile=.build/scripts/tui/index.js",
    "tui": "node scripts/run-tui.js",
    "check:tui": "node scripts/run-tui.js --help",
    "actions:validate": "node scripts/validate-actions.js"
  },
  "build": {
    "appId": "io.github.coletivo420.canva-linux",
    "productName": "Canva Linux",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "beforeBuild": "./scripts/electron-builder-before-build.js",
    "files": [
      ".build/electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": "dir",
      "category": "Graphics",
      "executableName": "canva-linux",
      "icon": "build-resources"
    },
    "appImage": {
      "artifactName": "canva-linux-${version}-${arch}.AppImage"
    },
    "extraMetadata": {
      "main": ".build/electron/main/index.js"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "blessed": "^0.1.81"
  },
  "desktopName": "io.github.coletivo420.canva-linux.desktop",
  "engines": {
    "node": ">=22.0.0"
  }
}
