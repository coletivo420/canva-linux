[Desktop Entry]
Type=Application
Name=Canva-Linux
GenericName=Design Tool
Comment=Unofficial Canva-Linux desktop wrapper using Electron/Chromium and Flatpak
Exec=run.sh
Icon=com.canva.Linux
Categories=Graphics;2DGraphics;
Keywords=canva;design;graphics;photo;editor;
StartupNotify=true
StartupWMClass=com.canva.Linux
X-GNOME-WMClass=com.canva.Linux
Actions=X11Fallback;

[Desktop Action X11Fallback]
Name=Canva-Linux (X11 fallback)
Exec=env CANVA_FORCE_X11=1 run.sh
